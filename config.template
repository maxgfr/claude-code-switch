# Claude Code Switch - Provider Configuration
#
# Format:
#   [provider_name]
#   base_url=https://...
#   api_key=your-api-key-here
#   models=model-a,model-b,model-c
#   default_model=model-a
#
# Special: [anthropic] does not need base_url (uses native API)
# Special: [_defaults] section sets global defaults

[_defaults]
provider=anthropic
model=claude-sonnet-4-6

[anthropic]
base_url=
api_key=
models=claude-sonnet-4-6,claude-opus-4-6,claude-haiku-4-5-20251001
default_model=claude-sonnet-4-6

[openrouter]
base_url=https://openrouter.ai/api/v1
api_key=
models=anthropic/claude-sonnet-4,openai/gpt-4o,google/gemini-2.5-pro
default_model=anthropic/claude-sonnet-4

[deepseek]
base_url=https://api.deepseek.com/v1
api_key=
models=deepseek-chat,deepseek-reasoner
default_model=deepseek-chat

[gemini]
base_url=https://generativelanguage.googleapis.com/v1beta/
api_key=
models=gemini-2.5-pro,gemini-2.5-flash
default_model=gemini-2.5-pro

[mistral]
base_url=https://api.mistral.ai/v1
api_key=
models=mistral-large-latest,codestral-latest
default_model=mistral-large-latest

[openai]
base_url=https://api.openai.com/v1
api_key=
models=gpt-4o,gpt-4o-mini,o3-mini
default_model=gpt-4o

[custom]
base_url=
api_key=
models=
default_model=
