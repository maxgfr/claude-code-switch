# Claude Code Switch - Provider Configuration
#
# Format:
#   [provider_name]
#   base_url=https://...
#   api_key=your-api-key-here
#   models=model-a,model-b,model-c
#   default_model=model-a
#
# Special: [anthropic] does not need base_url (uses native API)
# Special: [_defaults] section sets global defaults

[_defaults]
provider=anthropic
model=claude-sonnet-4-6

[anthropic]
base_url=
api_key=
models=claude-sonnet-4-6,claude-opus-4-6,claude-haiku-4-5-20251001
default_model=claude-sonnet-4-6

[openrouter]
base_url=https://openrouter.ai/api
api_key=
models=anthropic/claude-sonnet-4,openai/gpt-4o,google/gemini-2.5-pro
default_model=anthropic/claude-sonnet-4

[deepseek]
base_url=https://api.deepseek.com/anthropic
api_key=
models=deepseek-chat,deepseek-reasoner
default_model=deepseek-chat

[zai]
base_url=https://api.z.ai/api/coding/paas/v4
api_key=
models=glm-5,glm-4.6,glm-4.5
default_model=glm-4.6

[kimi]
base_url=https://api.moonshot.ai/anthropic/v1/messages
api_key=
models=kimi-k2.5
default_model=kimi-k2.5

[qwen]
base_url=https://dashscope-intl.aliyuncs.com/compatible-mode/anthropic
api_key=
models=qwen3.5-plus
default_model=qwen3.5-plus

[minimax]
base_url=https://api.minimax.io/anthropic
api_key=
models=m2.7,m2.5
default_model=m2.7

[custom]
base_url=
api_key=
models=
default_model=
