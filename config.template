# Claude Code Switch - Provider Configuration
#
# Format:
#   [provider_name]
#   base_url=https://...
#   api_key=your-api-key-here
#   model=model-name          (main model — maps to sonnet/default tier)
#   opus_model=model-name     (optional, for /models opus tier)
#   haiku_model=model-name    (optional, for /models haiku tier + fast tasks)
#
# Special: [anthropic] does not need base_url (uses native API)
# Special: [_defaults] section sets global defaults
# opus_model and haiku_model fall back to model if empty

[_defaults]
provider=anthropic
model=claude-sonnet-4-6

[anthropic]
base_url=
api_key=
model=claude-sonnet-4-6

[openrouter]
base_url=https://openrouter.ai/api
api_key=
model=anthropic/claude-sonnet-4

[deepseek]
base_url=https://api.deepseek.com/anthropic
api_key=
model=deepseek-chat
opus_model=deepseek-reasoner

[zai]
base_url=https://api.z.ai/api/anthropic
api_key=
model=glm-5.1
opus_model=glm-5.1
haiku_model=glm-4.7

[kimi]
base_url=https://api.moonshot.ai/anthropic
api_key=
model=kimi-k2.5

[qwen]
base_url=https://dashscope-intl.aliyuncs.com/apps/anthropic
api_key=
model=qwen3.5-plus
haiku_model=qwen3-coder-plus

[minimax]
base_url=https://api.minimax.io/anthropic
api_key=
model=MiniMax-M2.7
haiku_model=MiniMax-M2.5

[doubao]
base_url=https://ark.cn-beijing.volces.com/api/coding
api_key=
model=doubao-seed-code-preview-latest

[custom]
base_url=
api_key=
model=
